{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "prebuildCommand": "expo prebuild --no-install && node scripts/fix-podfile.js",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.25.126:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --no-install && node scripts/fix-podfile.js",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.25.126:8000"
      }
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "expo prebuild --no-install && node scripts/fix-podfile.js"
    }
  },
  "submit": {
    "production": {}
  }
}
