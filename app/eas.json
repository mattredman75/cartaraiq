{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "appExtensions": [
          {
            "targetName": "CartaraIQWidget",
            "bundleIdentifier": "com.cartaraiq.app.widget",
            "entitlements": {
              "com.apple.security.application-groups": ["group.com.cartaraiq.app"]
            }
          }
        ]
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.25.126:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "appExtensions": [
          {
            "targetName": "CartaraIQWidget",
            "bundleIdentifier": "com.cartaraiq.app.widget",
            "entitlements": {
              "com.apple.security.application-groups": ["group.com.cartaraiq.app"]
            }
          }
        ]
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.25.126:8000"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "appExtensions": [
          {
            "targetName": "CartaraIQWidget",
            "bundleIdentifier": "com.cartaraiq.app.widget",
            "entitlements": {
              "com.apple.security.application-groups": ["group.com.cartaraiq.app"]
            }
          }
        ]
      }
    }
  },
  "submit": {
    "production": {}
  }
}
